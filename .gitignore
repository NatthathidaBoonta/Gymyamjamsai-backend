# ============================================================
# .gitignore — Backend (Node.js + Express + Prisma)
# ============================================================

# ============================================================
# Dependencies
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================================
# Environment Variables (⚠️ ห้าม push ขึ้น GitHub เด็ดขาด)
# ============================================================
.env
.env.local
.env.development
.env.production
.env.staging

# ============================================================
# Prisma — Database Files
# ============================================================
# SQLite database files (dev)
prisma/*.db
prisma/*.db-journal
prisma/*.db-shm
prisma/*.db-wal

# ============================================================
# Logs
# ============================================================
logs/
*.log

# ============================================================
# OS Files
# ============================================================
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# ============================================================
# Editor / IDE
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# Build Output
# ============================================================
dist/
build/

# ============================================================
# Misc
# ============================================================
coverage/
.nyc_output/
